rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: workspaces
    // Document ID: {workspaceId}
    // Fields:
    //   - workspaceId: string (required)
    //   - aiProvider: string (required)
    //   - activeSource: string (required)
    //   - starterCreditsGranted: boolean
    //   - creditBalance: number
    //   - hasUserApiKey: boolean
    //   - userApiKeyStatus: string
    //   - userApiKeyEncrypted: string
    //   - updatedAt: string (ISO)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isWorkspaceMember(workspaceId) {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.workspaceId == workspaceId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "aimarketingagencynorge@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.uid is string &&
             data.email is string &&
             (!('credits' in data) || data.credits is number) &&
             (!('geminiApiKey' in data) || (data.geminiApiKey is string && data.geminiApiKey.size() < 200));
    }

    function isValidWorkspace(data) {
      return data.workspaceId is string &&
             data.aiProvider == 'gemini' &&
             data.activeSource in ['starter_credits', 'purchased_credits', 'user_api_key'] &&
             data.creditBalance is number &&
             data.creditBalance >= 0;
    }

    // Rules
    // User profiles
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId && !('role' in request.resource.data);
      allow update: if (isOwner(userId) && (request.resource.data.role == resource.data.role || isAdmin())) || isAdmin();

      match /brands/{brandId} {
        allow read, write: if isOwner(userId) || isAdmin();
        
        match /referenceImages/{imageId} {
          allow read, write: if isOwner(userId) || isAdmin();
        }
        
        match /assets/{assetId} {
          allow read, write: if isOwner(userId) || isAdmin();
        }
      }

      match /posts/{postId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      match /mediaAssets/{assetId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /studioAssets/{assetId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Workspaces
    match /workspaces/{workspaceId} {
      allow read: if isWorkspaceMember(workspaceId) || isAdmin() || isOwner(workspaceId);
      // Only server-side or admin can create/update sensitive fields
      allow write: if isAdmin() || isOwner(workspaceId);
      
      match /transactions/{historyId} {
        allow read: if isWorkspaceMember(workspaceId) || isAdmin() || isOwner(workspaceId);
        allow write: if false; // Only server can write history
      }
    }

    // Connection test path
    match /test/connection {
      allow read: if true;
    }
  }
}
